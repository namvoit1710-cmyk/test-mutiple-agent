#!/usr/bin/env bash
# myagent — OpenCode multi-agent CLI (v3, git worktree + PR)
set -euo pipefail
ORCH="${ORCHESTRATOR_URL:-http://localhost:8000}"

post() { curl -s -X POST "$ORCH/run" -H "Content-Type: application/json" -d "$1" | jq .; }

case "${1:-help}" in
  list)   curl -s "$ORCH/agents" | jq . ;;
  health) curl -s "$ORCH/health" | jq . ;;

  run)
    # No repo, just run a prompt (e.g. planner)
    agent="$2"; prompt="$3"
    post "$(jq -n --arg a "$agent" --arg p "$prompt" '{agent:$a, prompt:$p}')"
    ;;

  pr)
    # Full workflow: worktree -> code -> push -> create PR
    # Usage: myagent pr <agent> <repo-url> <base-branch> "<prompt>" ["pr title"]
    agent="$2"; repo="$3"; base="$4"; prompt="$5"; title="${6:-}"
    post "$(jq -n \
      --arg a "$agent" --arg p "$prompt" --arg r "$repo" \
      --arg b "$base" --arg t "$title" \
      '{agent:$a, prompt:$p, repo:$r, base_branch:$b,
        create_pr:true,
        pr_title: (if $t == "" then null else $t end)}')"
    ;;

  branch)
    # Worktree + push branch, but DON'T create PR
    agent="$2"; repo="$3"; base="$4"; prompt="$5"
    post "$(jq -n --arg a "$agent" --arg p "$prompt" --arg r "$repo" --arg b "$base" \
      '{agent:$a, prompt:$p, repo:$r, base_branch:$b, create_pr:false}')"
    ;;

  *)
    cat <<EOF
myagent — OpenCode multi-agent CLI

  list                                                       list agents
  health                                                     orchestrator health
  run    <agent> "<prompt>"                                  no repo (planner)
  branch <agent> <repo> <base> "<prompt>"                    worktree + push branch
  pr     <agent> <repo> <base> "<prompt>" ["title"]          worktree + push + open PR

Examples:
  myagent run planner "Design TODO API with auth"

  myagent pr be-engineer https://github.com/me/proj.git main \\
    "Add /users CRUD endpoint with tests" \\
    "feat(users): add CRUD endpoint"

  myagent branch fe-engineer https://github.com/me/proj.git main \\
    "Add login form component"

Environment:
  ORCHESTRATOR_URL    default http://localhost:8000
EOF
    ;;
esac
