{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": ["node", "@testing-library/jest-dom"]
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx", "vitest.config.ts"]
}
